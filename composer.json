{
    "name": "maxbrenne/nextcloudcalendar",
    "type": "phpbb-extension",
    "description": "phpBB extension for moderated calendar submissions to a Nextcloud CalDAV calendar.",
    "homepage": "https://github.com/MaBurn/phpbbNextcloudCalendarPlugin",
    "license": "GPL-2.0-only",
    "authors": [
        {
            "name": "Max Brenne"
        }
    ],
    "require": {
        "php": ">=7.4",
        "composer/installers": "~1.0 || ~2.0"
    },
    "extra": {
        "display-name": "Nextcloud Calendar",
        "soft-require": {
            "phpbb/phpbb": ">=3.3.0,<4.0.0"
        }
    }
}
